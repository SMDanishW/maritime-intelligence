# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql+asyncpg://marine:marine@localhost:5432/marine_traffic

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

# Groq Cloud
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Digitraffic Marine API (public, no auth required)
DIGITRAFFIC_BASE_URL=https://meri.digitraffic.fi
DIGITRAFFIC_TIMEOUT_SECONDS=10
DIGITRAFFIC_RETRY_ATTEMPTS=3

# Risk scoring weights (must sum to 100)
RISK_WEIGHT_VESSEL_DENSITY=25
RISK_WEIGHT_PORT_CONGESTION=20
RISK_WEIGHT_SEA_STATE=25
RISK_WEIGHT_ATON_FAULTS=15
RISK_WEIGHT_WINTER_NAVIGATION=15
